---
interface Props {
  id?: string;
  className?: string;
  ariaLabel?: string;
}
const { id, className = '', ariaLabel } = Astro.props;
---

<section
  id={id}
  aria-label={ariaLabel}
  class:list={['relative w-full scroll-mt-20 px-6 py-16 md:px-12 md:py-20', className]}
>
  <div class="mx-auto w-full max-w-coreMaxWidth">
    <slot />
  </div>
</section>
