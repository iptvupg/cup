---
import { SITE } from '../data/site';
---

<footer class="border-t border-hairline bg-canvas px-6 py-16 md:px-12">
  <div class="mx-auto w-full max-w-coreMaxWidth">
    <div class="mb-12">
      <!-- Brand col -->
      <div>
        <a href="/" class="flex items-center gap-1.5" aria-label="IPTV World Cup home">
          <span class="text-xl font-bold tracking-tight text-white">IPTV</span>
          <span
            class="rounded-sm bg-ch-yellow px-1.5 py-0.5 text-[11px] font-semibold uppercase tracking-[0.125em] text-on-yellow"
            >World Cup</span
          >
        </a>
        <p class="mt-4 text-sm leading-[1.55] text-muted">
          FIFA World Cup 2026 IPTV subscription plans for live football fans.
        </p>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between gap-4 border-t border-hairline pt-8 text-xs text-muted md:flex-row md:items-center">
      <p>
        © {new Date().getFullYear()} {SITE.name}. All rights reserved. FIFA World Cup 2026™ is a
        trademark of FIFA.
      </p>
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        <li><a href="/terms-of-use" class="hover:text-white">Terms of Use</a></li>
        <li><a href="/privacy-policy" class="hover:text-white">Privacy Policy</a></li>
        <li><a href="/privacy-choices" class="hover:text-white">Your Privacy Choices</a></li>
        <li><a href="/cookies" class="hover:text-white">Cookies</a></li>
        <li><a href="/sitemap" class="hover:text-white">Sitemap</a></li>
      </ul>
    </div>
  </div>
</footer>
