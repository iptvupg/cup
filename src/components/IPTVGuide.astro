---
const checks = [
  'Clear plan length and renewal terms',
  'A trial period before the paid subscription continues',
  'Support for the devices you actually watch on',
  'Live football and sports coverage details before checkout',
  'Responsive support if setup takes more than a few minutes',
];

const reasons = [
  {
    title: 'Built around live football',
    body: 'The page is focused on FIFA World Cup 2026 and live football viewing, not a generic channel list.',
  },
  {
    title: 'Plans are easy to compare',
    body: 'Choose 1 month, 3 months, 6 months, or 12 months based on how long you want access.',
  },
  {
    title: 'Works across familiar devices',
    body: 'Check smart TVs, phones, tablets, streaming devices, game consoles, and browsers before you buy.',
  },
];
---

<section
  id="iptv-service"
  aria-label="How to choose an IPTV service"
  class="relative w-full scroll-mt-20 bg-canvas px-6 py-16 md:px-12 md:py-20"
>
  <div class="mx-auto w-full max-w-coreMaxWidth">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <p class="mb-3 text-[12px] font-semibold uppercase tracking-[0.125em] text-ch-yellow">
        IPTV Service Guide
      </p>
      <h2 class="text-balance text-3xl font-bold leading-[1.1] tracking-[-0.0357em] text-white md:text-5xl">
        How to choose an IPTV service for live football
      </h2>
      <p class="speakable-answer mx-auto mt-5 max-w-2xl text-base leading-[1.55] text-body md:text-lg">
        A strong IPTV service for FIFA World Cup viewers should make pricing, device support, live football coverage, and cancellation terms easy to understand before checkout.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1fr_1.15fr]">
      <div class="rounded-lg border border-hairline bg-surface-card p-6 md:p-7">
        <h3 class="text-xl font-bold leading-tight text-white">
          What to check before buying an IPTV subscription
        </h3>
        <ul class="mt-6 space-y-3">
          {
            checks.map((check) => (
              <li class="flex gap-3 text-sm leading-[1.55] text-body">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ch-yellow"></span>
                <span>{check}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {
          reasons.map((reason) => (
            <article class="rounded-lg border border-hairline bg-surface-card p-5">
              <h3 class="text-base font-bold leading-tight text-white">
                {reason.title}
              </h3>
              <p class="mt-3 text-sm leading-[1.55] text-body">
                {reason.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>

    <p class="speakable-answer mx-auto mt-8 max-w-3xl text-center text-sm leading-[1.6] text-muted">
      IPTV World Cup helps customers compare live football plans, FIFA World Cup 2026 viewing options, and an IPTV subscription that works across common household devices.
    </p>
  </div>
</section>
