---
const desktopImg =
  'https://images.api.fox.com/dtc/pmt/promo/foxone_promo_lr_fwc_onboarding_2026_promo_unit_1778193500406.jpg?width=1728&height=*&fit=bounds&format=avif';
const mobileImg =
  'https://images.api.fox.com/dtc/pmt/container/foxone_promo_mobile_fwc_onboarding_2026_promo_unit_1778253875506.jpg?width=480&height=*&fit=bounds&format=avif';
const href = '#devices';
const alt = 'Pick your favorite FIFA World Cup 2026 team and get personalized match alerts on IPTV World Cup';
---

<section
  id="teams"
  aria-label="FIFA World Cup 2026 team onboarding"
  class="w-full scroll-mt-20 bg-canvas px-6 py-16 md:px-12 md:py-20"
  data-container-layout-type="D2C_LR_PROMO_BANNER"
>
  <div class="mx-auto w-full max-w-coreMaxWidth">
    <div class="mb-8 max-w-2xl">
      <p class="mb-3 text-[12px] font-semibold uppercase tracking-[0.125em] text-ch-yellow">
        Step 1 · Follow the tournament
      </p>
      <h2 class="text-balance text-3xl font-bold leading-[1.1] tracking-[-0.0357em] text-white md:text-4xl">
        One subscription path for a month of live football.
      </h2>
      <p class="mt-4 text-base leading-[1.55] text-body md:text-lg">
        FIFA World Cup 2026 runs from June 11 to July 19. Choose a plan that fits how long you want to watch, then stream the tournament from the group stage through the final.
      </p>
    </div>
    <a
      href={href}
      data-analytics="promo-banner-detail-page-link"
      data-testid="PromoBannerImage"
      class="group block w-full overflow-hidden rounded-lg ring-1 ring-hairline transition-colors duration-200 hover:ring-ch-yellow/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow"
      aria-label="Continue to supported devices"
    >
      <!-- Desktop / tablet -->
      <img
        src={desktopImg}
        alt={alt}
        width="1728"
        height="500"
        loading="lazy"
        decoding="async"
        class="hidden w-full transition-transform duration-500 group-hover:scale-[1.01] xsm:block"
      />
      <!-- Mobile -->
      <img
        src={mobileImg}
        alt={alt}
        width="480"
        height="318"
        loading="lazy"
        decoding="async"
        class="block w-full transition-transform duration-500 group-hover:scale-[1.01] xsm:hidden"
      />
    </a>
  </div>
</section>
