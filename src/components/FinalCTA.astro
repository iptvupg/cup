---
import { SITE } from '../data/site';
---

<section
  id="start"
  aria-label="Start your free trial"
  class="w-full scroll-mt-20 bg-canvas px-6 py-16 md:px-12 md:py-20"
>
  <div class="mx-auto max-w-coreMaxWidth">
    <div class="rounded-lg bg-ch-yellow p-8 text-on-yellow md:p-14">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 text-[12px] font-semibold uppercase tracking-[0.125em] text-on-yellow">
          Start with 24 hours free
        </p>
        <h2 class="mb-6 text-balance text-3xl font-bold leading-[1.15] tracking-[-0.0375em] text-on-yellow md:text-[40px]">
          Choose your IPTV plan before kickoff.
        </h2>
        <p class="mb-10 text-base font-medium leading-[1.55] text-on-yellow md:text-lg">
          Test IPTV World Cup free for {SITE.trialHours} hours, confirm it works on your device, then continue with the FIFA World Cup subscription plan that fits your tournament schedule.
        </p>
        <div class="flex flex-col items-center gap-4">
          <a
            href="#pricing"
            aria-label="Choose your IPTV World Cup plan"
            class="inline-flex h-12 items-center justify-center rounded-md bg-on-yellow px-8 text-[14px] font-semibold text-ch-yellow transition-colors hover:bg-canvas focus:outline-none focus-visible:ring-2 focus-visible:ring-on-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-ch-yellow"
          >
            Compare Plans
          </a>
          <p class="text-xs font-medium text-on-yellow">
            Then from $16 for 1 month or ${SITE.annualPrice} for 12 months. Cancel anytime.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
