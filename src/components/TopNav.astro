---
import NavLink from './NavLink.astro';
import { Menu } from 'lucide-astro';

const links = [
  { label: 'Home', href: '/#main' },
  { label: 'Devices', href: '/#devices' },
  { label: 'Guide', href: '/#iptv-service' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];
---

<header class="sticky top-0 z-50 border-b border-hairline/60 bg-canvas/95 backdrop-blur-md supports-[backdrop-filter]:bg-canvas/90">
  <nav
    class="mx-auto flex h-16 max-w-coreMaxWidth items-center justify-between px-6 md:px-12"
    aria-label="Primary navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-1.5 shrink-0" aria-label="IPTV World Cup home">
      <span class="text-lg font-bold tracking-tight text-white">IPTV</span>
      <span class="rounded-sm bg-ch-yellow px-1.5 py-0.5 text-[11px] font-semibold uppercase tracking-[0.125em] text-on-yellow"
        >World Cup</span
      >
    </a>

    <!-- Desktop center nav -->
    <ul class="hidden lg:flex items-center gap-8">
      {
        links.map((l) => (
          <li>
            <NavLink href={l.href}>{l.label}</NavLink>
          </li>
        ))
      }
    </ul>

    <!-- Desktop right actions -->
    <div class="hidden md:flex items-center gap-4 text-white">
      <a
        href="/iptv-free-trial"
        class="rounded-sm text-[14px] font-medium text-body transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-4 focus-visible:ring-offset-canvas"
        >24 Hours Free</a
      >
      <a
        href="/#pricing"
        class="inline-flex h-10 items-center justify-center rounded-md bg-ch-yellow px-4 text-[14px] font-semibold text-on-yellow transition-colors hover:bg-primary-active focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
        >View Plans</a
      >
    </div>

    <!-- Mobile menu (zero-JS via details/summary) -->
    <details class="md:hidden relative">
      <summary
        class="list-none cursor-pointer rounded p-2 text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
        aria-label="Open menu"
      >
        <Menu size={24} />
      </summary>
      <div
        class="absolute right-0 top-12 w-56 rounded-lg border border-hairline bg-surface-card/95 p-4 shadow-2xl backdrop-blur-md"
      >
        <ul class="flex flex-col gap-3">
          {
            links.map((l) => (
              <li>
                <a href={l.href} class="block rounded-sm text-[15px] font-medium text-body hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-4 focus-visible:ring-offset-surface-card">
                  {l.label}
                </a>
              </li>
            ))
          }
          <li class="mt-2 border-t border-hairline pt-3">
            <a href="/iptv-free-trial" class="block rounded-sm text-[15px] font-medium text-body hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-4 focus-visible:ring-offset-surface-card">
              24 Hours Free
            </a>
          </li>
          <li>
            <a
              href="/#pricing"
              class="inline-flex h-10 w-full items-center justify-center rounded-md bg-ch-yellow px-4 text-[14px] font-semibold text-on-yellow focus:outline-none focus-visible:ring-2 focus-visible:ring-ch-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-surface-card"
              >View Plans</a
            >
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>

<style>
  /* Hide default disclosure marker */
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }
</style>
