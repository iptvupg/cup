---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from './TopNav.astro';
import Footer from './Footer.astro';
import { SITE } from '../data/site';

interface Section {
  title: string;
  body?: string;
  items?: string[];
}

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  eyebrow: string;
  heading: string;
  intro: string;
  sections: Section[];
}

const {
  title,
  description,
  canonicalPath,
  eyebrow,
  heading,
  intro,
  sections,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${SITE.domain}${canonicalPath}`}
  includeSchema={false}
>
  <TopNav />
  <main id="main" class="bg-canvas px-6 py-16 md:px-12 md:py-24">
    <article class="mx-auto max-w-3xl">
      <p class="mb-4 text-[12px] font-semibold uppercase tracking-[0.125em] text-ch-yellow">
        {eyebrow}
      </p>
      <h1 class="text-balance text-4xl font-bold leading-[1.05] tracking-[-0.02em] text-white md:text-6xl">
        {heading}
      </h1>
      <p class="mt-6 text-base leading-[1.65] text-body md:text-lg">
        {intro}
      </p>
      <p class="mt-4 text-sm leading-[1.6] text-muted">
        Last updated: {SITE.lastUpdated}
      </p>

      <div class="mt-12 space-y-8">
        {
          sections.map((section) => (
            <section class="rounded-lg border border-hairline bg-surface-card p-6 md:p-7">
              <h2 class="text-xl font-bold leading-tight text-white">
                {section.title}
              </h2>
              {section.body && (
                <p class="mt-4 text-sm leading-[1.65] text-body md:text-base">
                  {section.body}
                </p>
              )}
              {section.items && (
                <ul class="mt-4 space-y-3">
                  {section.items.map((item) => (
                    <li class="flex gap-3 text-sm leading-[1.6] text-body md:text-base">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ch-yellow"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          ))
        }
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
