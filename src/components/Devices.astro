---
import SectionWrapper from './SectionWrapper.astro';
import DeviceIcon from './DeviceIcon.astro';
import { DEVICES } from '../data/site';
---

<SectionWrapper
  id="devices"
  ariaLabel="Supported streaming devices for IPTV World Cup"
  className="bg-surface-soft"
>
  <div class="mb-12 text-center">
    <p class="mb-3 text-[12px] font-semibold uppercase tracking-[0.125em] text-ch-yellow">
      Step 2 · Watch Anywhere
    </p>
    <h2 class="mx-auto max-w-3xl text-balance text-3xl font-bold leading-[1.1] tracking-[-0.0357em] text-white md:text-5xl">
      Stream live football on the screens you already use
    </h2>
    <p class="speakable-answer mx-auto mt-5 max-w-2xl text-base leading-[1.55] text-body md:text-lg">
      IPTV World Cup is built for customers who want a simple FIFA World Cup IPTV subscription across smart TVs, streaming sticks, phones, tablets, consoles, and web browsers.
    </p>
  </div>

  <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
    {
      DEVICES.map((d) => (
        <li class="group flex flex-col items-center justify-center gap-3 rounded-lg border border-hairline bg-surface-card px-4 py-6 text-center text-sm font-semibold text-body-strong transition-colors hover:border-ch-yellow/40 hover:bg-surface-elevated hover:text-white">
          <DeviceIcon name={d.icon} class="h-8 w-8 text-body transition-colors group-hover:text-ch-yellow" />
          <span>{d.name}</span>
        </li>
      ))
    }
  </ul>
</SectionWrapper>
