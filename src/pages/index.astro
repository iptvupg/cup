---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import HeroSection from '../components/HeroSection.astro';
import JourneyRail from '../components/JourneyRail.astro';
import PromoBanner from '../components/PromoBanner.astro';
import Devices from '../components/Devices.astro';
import IPTVGuide from '../components/IPTVGuide.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="IPTV Service for Live Football | IPTV Subscription from $16"
  description="Learn what IPTV is, compare IPTV service plans for live football, and start a 24-hour trial before choosing a World Cup 2026 IPTV subscription from $16."
>
  <TopNav />
  <main id="main">
    <HeroSection />
    <JourneyRail />
    <PromoBanner />
    <Devices />
    <IPTVGuide />
    <Pricing />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
